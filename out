	write_instructions(out.asm.file, prog);
	int	_ = system(out.asm.cmd);
	fclose(out.asm.file);
	_ = system(out.object.cmd);
	// remove(out.asm.path);
	// remove(out.object.path);
	(void)_;
	return EXIT_SUCCESS;
}

